{
  "name": "meow",
  "version": "1.0.0",
  "description": "Electron wrapper for Meow",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run next\" \"npm run electron\"",
    "next": "cd meow && npm run dev",
    "electron": "wait-on http://localhost:3000 && electron ."
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "tailwindcss": "^4",
    "@tailwindcss/postcss": "^4"
  },
  "build": {
    "appId": "com.meow.app",
    "productName": "Meow",
    "win": {
      "icon": "electron/Meow_logo.png"
    }
  }
}